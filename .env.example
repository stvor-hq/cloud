# Key encryption password — CHANGE IN PRODUCTION
STVOR_KEY_PASSWORD=your-strong-password-here
STVOR_KEY_DIR=./data/keys

# Relay configuration
STVOR_RELAY_URL=
STVOR_APP_TOKEN=
STVOR_AGENT_ID=
STVOR_ALLOW_MOCK=
# STVOR_ALLOW_MOCK=true is required to explicitly allow using the mock relay when
# STVOR_RELAY_URL is not set or set to 'mock'. In production, always set
# STVOR_RELAY_URL to your production relay (wss://) and leave STVOR_ALLOW_MOCK unset.

# Enterprise Production Mode
STVOR_PRODUCTION_MODE=false
# When true:
#  - STVOR_RELAY_URL must be set and use wss://
#  - STVOR_ALLOW_MOCK is ignored
#  - STVOR_API_KEY is required
#  - STVOR_KEY_PASSWORD is required (no auto-generation)

# API authentication
STVOR_API_KEY=stvor-demo-key

# Challenge persistence (for production clusters, use Redis instead)
STVOR_CHALLENGE_STORE=./data/challenges.json
STVOR_RATE_LIMIT_STORE=./data/rate-limits.json

# Relay token (required in production for relay server)
RELAY_TOKEN=stvor-relay-dev-token

# On-chain deployment (Sepolia)
SEPOLIA_RPC_URL=https://rpc.sepolia.org
DEPLOYER_PRIVATE_KEY=your-private-key-here
